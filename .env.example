# ── SMTP Configuration ──────────────────────────────────────────────
# Required for the contact form to send emails
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@example.com
SMTP_PASS=your-app-password
SMTP_FROM=noreply@151.lu

# ── Contact ─────────────────────────────────────────────────────────
# Email address that receives contact form submissions
CONTACT_EMAIL=contact@151.lu

# ── Site ────────────────────────────────────────────────────────────
# Used for SEO metadata (canonical URLs, OG tags)
SITE_URL=https://151.lu
